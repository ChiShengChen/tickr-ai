# ─── Demo Mode ────────────────────────────────────────────────────────────────
# Flip both to 'true' to run the full UX without external credentials
# (Privy / Anthropic / DB / wallet). Demo path short-circuits every API
# route + the ws-server signal loop; live trading paths are skipped.
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false
DEMO_INTERVAL_SECONDS=20

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_TRADE_USD=5

# ─── Auth & Wallet (Privy) ────────────────────────────────────────────────────
# Register at https://dashboard.privy.io — enable embedded Solana wallets.
# App ID starts with "cm", 20+ characters.
#
# Phase F + G changes:
#   - PRIVY_APP_SECRET is also used server-side by /api/* middleware
#     and the ws-server socket auth handler to verifyAuthToken().
#   - PRIVY_APP_ID (no NEXT_PUBLIC_ prefix) is read by the ws-server's
#     server-auth client; normally the same value as NEXT_PUBLIC_PRIVY_APP_ID.
#   - Production needs Privy Pro plan for server signers (auto TP/SL
#     placement + OCO sibling cancellation). Free plan still works for
#     login + manual trades; the auto-exit toggle in Settings shows a
#     warning banner when delegation can't actually fire.
#   - Demo mode bypasses all of the above.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── Solana RPC ───────────────────────────────────────────────────────────────
# Comma-separated list. parseRpcUrls round-robins through them so a provider
# outage rolls over to the next one. Put a paid endpoint (Helius / Triton /
# QuickNode) first in production:
#   NEXT_PUBLIC_SOLANA_RPC_URLS=https://mainnet.helius-rpc.com/?api-key=<key>,https://solana-rpc.publicnode.com/
#
# Free public RPCs (tested, support getTokenAccountsByOwner):
#   https://solana-rpc.publicnode.com/        (publicnode — blocks getTokenAccountsByOwner ⚠️ keep behind failover)
#   https://solana.leorpc.com/?api_key=FREE
#   https://solana.api.pocket.network/
#   https://public.rpc.solanavibestation.com/
#   https://api.mainnet-beta.solana.com       (Solana Foundation, aggressive rate limits)
NEXT_PUBLIC_SOLANA_RPC_URLS=https://solana-rpc.publicnode.com/,https://solana.leorpc.com/?api_key=FREE,https://solana.api.pocket.network/,https://public.rpc.solanavibestation.com/,https://api.mainnet-beta.solana.com

# ─── Jupiter ──────────────────────────────────────────────────────────────────
# Ultra (market swap, used by panic-close + post-Approve close flow).
# No API key needed; lite-api is rate-limited but free.
NEXT_PUBLIC_JUPITER_API_BASE=https://lite-api.jup.ag

# Trigger v2 (place / cancel / history of conditional orders). Requires
# an API key (x-api-key, server-side via /api/jupiter proxy) and a
# per-wallet JWT obtained via challenge/verify (lib/jupiter/auth.ts).
# Apply at https://portal.jup.ag (sign in with Solana wallet → API Keys).
# Browser bundle reads NEXT_PUBLIC_JUPITER_API_KEY at build time but the
# value is only used by /api/jupiter proxy server-side; the browser
# never ships the header itself (Jupiter rejects x-api-key in CORS).
NEXT_PUBLIC_JUPITER_API_BASE_V2=https://api.jup.ag
NEXT_PUBLIC_JUPITER_API_KEY=

# ─── Pyth (Price Data) ───────────────────────────────────────────────────────
# Hermes      = real-time prices for the Signal Engine.
# Benchmarks  = historical OHLC bars for charts + back-evaluation cron.
# Public endpoints, no API key required. 30 req / 10s per IP.
PYTH_HERMES_URL=https://hermes.pyth.network
PYTH_BENCHMARKS_URL=https://benchmarks.pyth.network

# ─── LLM (Anthropic) ─────────────────────────────────────────────────────────
# Used by the ws-server Signal Engine (Claude Haiku 4.5). Daily USD cap
# triggers fallback to the rule-based scorer once exceeded. Empty key
# disables LLM analysis entirely; fixture-only signals continue.
ANTHROPIC_API_KEY=
LLM_ENABLED=true
LLM_DAILY_USD_CAP=20

# ─── Signal Engine ────────────────────────────────────────────────────────────
# BYPASS_MARKET_HOURS=true lets the generator emit even when Pyth quotes
# are stale (US equities closed). Useful for hackathon / demo; turn off
# in production so the system respects market gating.
SIGNAL_INTERVAL_SECONDS=60
TICKER_STAGGER_SECONDS=2
BYPASS_MARKET_HOURS=false

# ─── Database (PostgreSQL 16) ─────────────────────────────────────────────────
# Both apps/web and apps/ws-server connect to the same Postgres instance.
# URL-encode special chars in password.
# Format:
#   postgresql://<user>:<password>@<host>:<port>/<dbname>
# Local docker-compose:
#   postgresql://hunch:hunch@localhost:5432/hunchit
# GCP Cloud SQL via private IP:
#   postgresql://hunch:<pw>@10.x.x.x:5432/hunch
# GCP Cloud SQL Auth Proxy (local → cloud):
#   postgresql://hunch:<pw>@127.0.0.1:5432/hunch
DATABASE_URL=

# ─── Cache (Upstash Redis, optional) ─────────────────────────────────────────
# Used by ws-server signal cache + web Pyth bars cache + signal de-dup.
# Empty values disable the cache layer transparently.
# Provision a free DB at https://console.upstash.com/redis.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── WebSocket (ws-server) ────────────────────────────────────────────────────
# NEXT_PUBLIC_WS_URL is the URL the BROWSER uses for Socket.IO. Baked
# into the JS bundle at Next build time, so set it before `next build`
# (or pass as a Docker build arg).
# WS_CRON_SECRET protects the ws-server's /cron/generate /cron/evaluate
# /cron/track-orders endpoints — Cloud Scheduler / Vercel Cron must
# send this in the Authorization header. Generate with:
#   openssl rand -hex 32
NEXT_PUBLIC_WS_URL=http://localhost:4000
WS_SERVER_PORT=4000
WS_CRON_SECRET=change-me-shared-secret

# ─── Back-evaluation (ws-server) ─────────────────────────────────────────────
# Optional overrides for the Phase G back-evaluator cron. Defaults are
# sane for hackathon (5min interval, ±0.5% WIN threshold on 1h moves).
# BACK_EVAL_INTERVAL_MS=300000
# BACK_EVAL_WIN_THRESHOLD_PCT=0.5
