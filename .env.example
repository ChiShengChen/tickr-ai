# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# Jupiter
NEXT_PUBLIC_JUPITER_API_BASE=https://lite-api.jup.ag

# Pyth
PYTH_HERMES_URL=https://hermes.pyth.network
PYTH_BENCHMARKS_URL=https://benchmarks.pyth.network

# LLM
ANTHROPIC_API_KEY=
LLM_ENABLED=true
LLM_DAILY_USD_CAP=10

# Signal engine
SIGNAL_INTERVAL_SECONDS=60
TICKER_STAGGER_SECONDS=2
BYPASS_MARKET_HOURS=false

# Database (Neon Postgres)
DATABASE_URL=

# Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# WebSocket
NEXT_PUBLIC_WS_URL=http://localhost:4000
WS_SERVER_PORT=4000
WS_CRON_SECRET=change-me-shared-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
