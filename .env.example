# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# Privy (auth + embedded wallet) — register an app at https://dashboard.privy.io
# Demo mode works without it (a placeholder appId is used and the provider stays
# in not-ready state, which is fine because demo bypasses the wallet flow).
NEXT_PUBLIC_PRIVY_APP_ID=

# Jupiter
NEXT_PUBLIC_JUPITER_API_BASE=https://lite-api.jup.ag

# Pyth
PYTH_HERMES_URL=https://hermes.pyth.network
PYTH_BENCHMARKS_URL=https://benchmarks.pyth.network

# LLM
ANTHROPIC_API_KEY=
LLM_ENABLED=true
LLM_DAILY_USD_CAP=10

# Signal engine
SIGNAL_INTERVAL_SECONDS=60
TICKER_STAGGER_SECONDS=2
BYPASS_MARKET_HOURS=false

# Database (Neon Postgres)
DATABASE_URL=

# Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# WebSocket
NEXT_PUBLIC_WS_URL=http://localhost:4000
WS_SERVER_PORT=4000
WS_CRON_SECRET=change-me-shared-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo mode — flip both to 'true' to run the full UX without any external
# credentials (no Helius / Anthropic / Neon / Upstash / wallet). ws-server
# emits hand-crafted signals every DEMO_INTERVAL_SECONDS; swap + persistence
# are simulated in-memory.
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false
DEMO_INTERVAL_SECONDS=20
