# ─── Solana RPC ───────────────────────────────────────────────────────────────
# Comma-separated list of Solana RPC endpoints. The app round-robins through
# them so if one provider goes down the next one takes over automatically.
# Falls back to the public mainnet endpoint when empty (rate-limited, not for production).
#
# For production, put your Helius (or paid) endpoint first:
#   NEXT_PUBLIC_SOLANA_RPC_URLS=https://mainnet.helius-rpc.com/?api-key=<key>,https://solana-rpc.publicnode.com/
#
# Free public RPCs (tested, support getTokenAccountsByOwner):
#   https://solana-rpc.publicnode.com/
#   https://solana.leorpc.com/?api_key=FREE
#   https://solana.api.pocket.network/
#   https://api.mainnet-beta.solana.com          (Solana Foundation, aggressive rate limits)
#   https://public.rpc.solanavibestation.com/
NEXT_PUBLIC_SOLANA_RPC_URLS=https://solana-rpc.publicnode.com/,https://solana.leorpc.com/?api_key=FREE,https://solana.api.pocket.network/,https://public.rpc.solanavibestation.com/,https://api.mainnet-beta.solana.com

# ─── Auth & Wallet (Privy) ────────────────────────────────────────────────────
# Register at https://dashboard.privy.io — enable embedded Solana wallets.
# App ID starts with "cm", 20+ characters.
# Demo mode works without it (provider stays not-ready, demo bypasses wallet).
NEXT_PUBLIC_PRIVY_APP_ID=

# ─── Jupiter ──────────────────────────────────────────────────────────────────
# Jupiter Ultra API (gas-sponsored swaps). No API key required for basic use.
NEXT_PUBLIC_JUPITER_API_BASE=https://lite-api.jup.ag

# ─── Pyth (Price Data) ───────────────────────────────────────────────────────
# Public endpoints, no API key required. 30 req / 10s per IP.
PYTH_HERMES_URL=https://hermes.pyth.network
PYTH_BENCHMARKS_URL=https://benchmarks.pyth.network

# ─── LLM (Anthropic) ─────────────────────────────────────────────────────────
# Used by the Signal Engine (ws-server only). Leave empty to skip LLM calls.
ANTHROPIC_API_KEY=
LLM_ENABLED=true
LLM_DAILY_USD_CAP=10

# ─── Signal Engine ────────────────────────────────────────────────────────────
SIGNAL_INTERVAL_SECONDS=60
TICKER_STAGGER_SECONDS=2
BYPASS_MARKET_HOURS=false

# ─── Database (GCP Cloud SQL — PostgreSQL 15) ─────────────────────────────────
# Both apps/web and apps/ws-server connect to the same Cloud SQL instance.
# For local dev, any PostgreSQL works. URL-encode special chars in password.
# Format:
#   postgresql://<user>:<password>@<host>:<port>/<dbname>
# GCP Cloud SQL via private IP (production):
#   postgresql://hunch:password@10.x.x.x:5432/hunch
# GCP Cloud SQL via Cloud SQL Auth Proxy (local → cloud):
#   postgresql://hunch:password@127.0.0.1:5432/hunch
DATABASE_URL=

# ─── WebSocket (ws-server) ────────────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=http://localhost:4000
WS_SERVER_PORT=4000
WS_CRON_SECRET=change-me-shared-secret

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_TRADE_USD=5

# ─── Demo Mode ────────────────────────────────────────────────────────────────
# Flip both to 'true' to run the full UX without external credentials.
# ws-server emits fake signals every DEMO_INTERVAL_SECONDS.
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false
DEMO_INTERVAL_SECONDS=20
