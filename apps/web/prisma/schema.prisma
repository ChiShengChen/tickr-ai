// SignalDesk — shared Prisma schema (GCP Cloud SQL / PostgreSQL 15)
// Ships the five tables from the bootstrap spec: users, signals, approvals,
// trades, positions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  walletAddress String     @unique
  createdAt     DateTime   @default(now())
  approvals     Approval[]
  trades        Trade[]
  positions     Position[]
}

model Signal {
  id            String         @id @default(cuid())
  ticker        String
  action        SignalAction
  confidence    Float
  rationale     String         @db.Text
  ttlSeconds    Int
  priceAtSignal Float
  indicators    Json
  createdAt     DateTime       @default(now())
  expiresAt     DateTime

  // Back-evaluation: filled in by the 5-min cron once createdAt+1h has elapsed.
  // priceAfter = close of the 5-min Pyth Benchmarks bar containing createdAt+1h.
  // pctChange  = (priceAfter - priceAtSignal) / priceAtSignal.
  // outcome    = WIN / LOSS / NEUTRAL (HOLD or |pctChange| < 0.1%).
  evaluatedAt   DateTime?
  priceAfter    Float?
  pctChange     Float?
  outcome       SignalOutcome?

  approvals     Approval[]
  trades        Trade[]

  @@index([createdAt])
  @@index([ticker, createdAt])
  @@index([evaluatedAt])
}

model Approval {
  id         String   @id @default(cuid())
  userId     String
  signalId   String
  decision   Boolean
  decidedAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  signal     Signal   @relation(fields: [signalId], references: [id])

  @@unique([userId, signalId])
}

model Trade {
  id             String   @id @default(cuid())
  userId         String
  signalId       String?
  ticker         String
  side           String
  amountUsd      Float
  tokenAmount    Float
  executionPrice Float
  txSignature    String   @unique
  status         String
  realizedPnl    Float    @default(0)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
  signal         Signal?  @relation(fields: [signalId], references: [id])

  @@index([userId, createdAt])
}

model Position {
  id          String   @id @default(cuid())
  userId      String
  ticker      String
  tokenAmount Float
  avgCost     Float
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, ticker])
}

enum SignalAction {
  BUY
  SELL
  HOLD
}

enum SignalOutcome {
  WIN
  LOSS
  NEUTRAL
}
